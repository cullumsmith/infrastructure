APP_NAME=Laravel
APP_ENV=production
APP_KEY=${phpldapadmin_app_key}
APP_DEBUG=false

LOG_CHANNEL=syslog

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

LDAP_HOST=${fqdn}
LDAP_BASEDN=${basedn}
LDAP_CONNECTION=ldaps
LDAP_USERNAME=${phpldapadmin_dn}
LDAP_PASSWORD=${phpldapadmin_password}
LDAP_CACHE=true
LDAP_ALERT_ROOTDN=true
LDAP_LOGIN_ATTR=uid
LDAP_LOGIN_OBJECTCLASS=inetOrgPerson
LDAP_NAME="${site}"
